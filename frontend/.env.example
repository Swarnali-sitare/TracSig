# Copy to .env. Vite only exposes variables prefixed with VITE_.

# Base URL of the Flask API (scheme + host + port, no trailing slash).
# Request paths in the app already start with /api/...
# Local dev (API on port 5000):
VITE_API_URL=http://127.0.0.1:5000

# Production example:
# VITE_API_URL=https://api.yourdomain.com
