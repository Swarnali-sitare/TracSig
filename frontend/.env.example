# Vite exposes only variables prefixed with VITE_.
# Copy to .env.development / .env.production as needed.

# Base URL of the Flask API (no trailing slash). Used when you wire the SPA to the backend.
# Development (Vite dev server + Flask on 5000):
# VITE_API_BASE_URL=http://127.0.0.1:5000/api
# Production (your API hostname):
# VITE_API_BASE_URL=https://api.yourdomain.com/api

VITE_API_BASE_URL=http://127.0.0.1:5000/api
