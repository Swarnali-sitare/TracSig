# Copy to .env and adjust. Never commit .env.

# --- Flask ---
# Use production for live servers (disables Flask debug behaviour).
FLASK_ENV=development
# FLASK_ENV=production

# --- Security (required for production) ---
# Generate e.g.: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
JWT_SECRET_KEY=

# --- Database ---
# Special characters in the password must be URL-encoded (e.g. @ -> %40).
# PostgreSQL 15+: if you see "permission denied for schema public", run as superuser:
#   GRANT ALL ON SCHEMA public TO your_db_user;
# Local (Docker Compose in repo root): postgresql://tracsig:tracsig@localhost:5432/tracsig
# Managed hosts often provide DATABASE_URL; postgres:// is auto-normalized to postgresql://
DATABASE_URL=postgresql://tracsig:tracsig@localhost:5432/tracsig

# --- CORS ---
# Comma-separated origins of your deployed SPA (scheme + host, no trailing slash on path)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- JWT ---
ACCESS_TOKEN_EXPIRES=900
REFRESH_TOKEN_EXPIRES_DAYS=7

# --- API ---
MAX_CONTENT_LENGTH=2097152

# --- Reverse proxy (nginx, Traefik, load balancer) ---
# Set to 1 when the app is behind a trusted proxy that sets X-Forwarded-* headers.
TRUST_PROXY=0

# Optional: SQLAlchemy pool recycle (seconds), default 280
# SQLALCHEMY_POOL_RECYCLE=280
