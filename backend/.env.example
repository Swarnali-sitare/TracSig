# PostgreSQL must be running on localhost:5432 with database "tracsig" (user/password as in URL).
# From repo root with Docker: docker compose up -d
# Then: cd backend && py init_db.py   (Windows: use py if python is not on PATH)

SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
DATABASE_URL=postgresql://postgres:password@localhost:5432/tracsig
FLASK_ENV=development
FLASK_DEBUG=1
